{
	"name": "Ona",
	"build": {
		"context": ".",
		"dockerfile": "Dockerfile"
	},
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:2": {
			"moby": false,
			"dockerDashComposeVersion": "v2"
		},
		"ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
			"version": "latest",
			"helm": "latest",
			"minikube": "none"
		},
		"ghcr.io/devcontainers/features/go:1": {
			"version": "1.24"
		}
	},
	"forwardPorts": [8080, 8443, 9080],
	"portsAttributes": {
		"8080": {
			"label": "PipeCD Web UI",
			"onAutoForward": "notify"
		},
		"8443": {
			"label": "PipeCD API",
			"onAutoForward": "notify"
		},
		"9080": {
			"label": "PipeCD Ops",
			"onAutoForward": "notify"
		}
	},
	"postCreateCommand": "go install sigs.k8s.io/controller-runtime/tools/setup-envtest@latest && curl -Lo /usr/local/bin/kind https://kind.sigs.k8s.io/dl/v0.25.0/kind-linux-amd64 && chmod +x /usr/local/bin/kind",
	"postStartCommand": "chmod +x .devcontainer/start-port-forwards.sh && .devcontainer/start-port-forwards.sh",
	"remoteUser": "root"
}
